!setup.pl -d=3
 &filelist
        base_filename='data/solar_bipolar_atmb'
        saveprim=.true.
        convert_type='vtuBCCmpi'
        autoconvert=.false.
        nwauxio=9
 /
        convert_type='vtuBCCmpi'

 &savelist
        itsave(1,1)=0
        itsave(1,2)=0
        ditsave_log=1
        dtsave_dat=1.d0
 /
        dtsave_custom=0.05d0

 &stoplist
        time_max=10.0d0
 /
it_max=1
/
 &methodlist
        time_stepper=  'threestep'
        flux_scheme=    20*'hll'
        limiter= 20*'vanleer'
        fix_small_values   = .false.
        check_small_values = .true.
 /
        check_small_values=.true.
        tvdlfeps=0.d0
        trace_small_values=.true.
        typeboundspeed='cmaxmean'

 &boundlist
        typeboundary_min1=8*'special',4*'symm'
        typeboundary_max1=8*'special',4*'symm'
        typeboundary_min2=8*'special',4*'symm'
        typeboundary_max2=8*'special',4*'symm'
        typeboundary_min3=8*'special',4*'special'
        typeboundary_max3=8*'special',4*'cont'
 /

 &meshlist
        refine_max_level=3
        refine_threshold=20*0.2d0
        block_nx1=20
        block_nx2=20
        block_nx3=20
        domain_nx1=40
        domain_nx2=40
        domain_nx3=40
        iprob=1
        xprobmin1=-6.0d0
        xprobmax1=6.0d0
        xprobmin2=-6.0d0
        xprobmax2=6.0d0
        xprobmin3=0.d0
        xprobmax3=12.d0
 /
        w_refine_weight(1)=0.4d0
        w_refine_weight(6)=0.2d0
        w_refine_weight(7)=0.2d0
        w_refine_weight(8)=0.2d0
        xprobmin1=-10.0d0
        xprobmax1=10.0d0
        xprobmin2=-10.0d0
        xprobmax2=10.0d0
        xprobmin3=0.d0
        xprobmax3=40.d0

 &paramlist
        typecourant='maxsum'
        courantpar=0.8d0
 /

 &uawsom_list
        uawsom_energy=.true.
        uawsom_gravity=.true.
        typedivbfix='linde'
        uawsom_thermal_conduction=.true.
        uawsom_radiative_cooling=.true.
        uawsom_trac=.true.
        Busr=30.d0
 /
        typedivbfix='glm'
        typedivbfix='linde'
        B0field=.true.
        B0field_forcefree=.true.
        uawsom_adiab=0.d0