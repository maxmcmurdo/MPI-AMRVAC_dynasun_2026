!========================================================================================
! Parameter file for 2.5D x-y prominence - combination of my previous work par file and test example mhd/solar_atmosphere_2.5D par file
! Update  : 04/08/2022
!========================================================================================

 &filelist
        base_filename = 'data_test/2_5Dprominence_'
        saveprim      = .true.
        convert   = .false.
        convert_type  = 'vtuCCmpi'
/
        restart_from_file = 'data_1d1WAkpmB0depInitInj_wRef_long_wCT_ref_corrected/2_5Dprominence_0056.dat'
	snapshotnext=57
/

 &savelist
        itsave(1,1) = 0
        itsave(1,2) = 0
        dtsave_log  = 0.1d0
        dtsave_dat  = 0.1d0
/

 &stoplist
        dtmin    = 1.d-6
        time_max = 10.0d0
/
	it_max=1
 /
 &methodlist
        time_stepper       = 'threestep'  ! was threestep
        flux_scheme        = 20*'hll'
        limiter            = 20*'vanleer' ! was vanleer
        fix_small_values   = .false.
        check_small_values = .true.
/
! rho m1 m2 m3 e b1 b2 b3 wkpm wApm
&boundlist
       typeboundary_min1 = 'symm','asymm','symm','symm','symm','asymm','symm','symm',2*'symm',2*'symm'
       typeboundary_max1 = 'symm','asymm','symm','symm','symm','asymm','symm','symm',2*'symm',2*'symm'
       typeboundary_min2 = 8*'special',2*'special',2*'special'
       typeboundary_max2 = 8*'special',4*'cont'
/

 &meshlist
        refine_criterion = 3
        refine_max_level = 2  !-> 2lvs: 250km x 250 km, 5lvls: 31.25km x 31.25km
        block_nx1        = 10
        block_nx2        = 10
        domain_nx1       = 100
        domain_nx2       = 80
        xprobmin1        = -5.d0
        xprobmax1        = +5.0d0
        xprobmin2        = 0.0d0
        xprobmax2        = 8.0d0
 /

 &paramlist
        typecourant='maxsum'
        courantpar=0.8d0
 /


  &uawsom_list
         uawsom_gravity   = .true.
         uawsom_gamma     = 1.6667d0
         typedivbfix   = 'lindepowel'
         uawsom_thermal_conduction = .true.
         uawsom_radiative_cooling = .true.
         uawsom_trac = .true.
         uawsom_trac_type = 2
         uawsom_energy=.true.
	 uawsom_solve_eaux=.false.
	 uawsom_internal_e=.false.
	 uawsom_hydrodynamic_e=.false.
         Busr=10.d0    !in G
         B0field=.true.
  /

 &tc_list
        tc_perpendicular=.false.
        tc_saturate=.true.
 /

  &rc_list
         ncool = 4000
         coolcurve = 'Colgan_DM'
         coolmethod = 'exact'
         tlow       = 4.17d-3
         Tfix       = .true.
  /